@echo off
chcp 65001 >nul
REM ==========================================================================
REM  run.bat — запуск генератора видео в один двойной клик (без VS Code)
REM
REM  Что делает по шагам:
REM    1) Переходит в свою папку (где лежит этот файл).
REM    2) Включает АНТИСОН (компьютер не уснёт во время батча).
REM    3) Активирует venv и запускает generate.py.
REM    4) КОГДА БАТЧ ЗАКОНЧИЛСЯ (или окно закрыли) — ВОЗВРАЩАЕТ сон обратно.
REM
REM  Возврат сна сделан максимально надёжно: он стоит ПЕРВЫМ делом при выходе,
REM  поэтому срабатывает и при нормальном завершении, и при ошибке скрипта.
REM ==========================================================================

REM --- Переходим в папку, где лежит сам этот .bat (на всякий случай) ---
cd /d "%~dp0"

echo ==========================================================
echo  ВКЛЮЧАЮ АНТИСОН (компьютер не будет засыпать во время работы)
echo ==========================================================
REM 0 = "никогда". Ставим и для сети (ac), и для батареи (dc).
powercfg /change standby-timeout-ac 0
powercfg /change standby-timeout-dc 0
powercfg /change hibernate-timeout-ac 0
powercfg /change hibernate-timeout-dc 0

echo.
echo ==========================================================
echo  ЗАПУСКАЮ ГЕНЕРАТОР. Не закрывай это окно до конца работы.
echo ==========================================================
echo.

REM --- Активируем виртуальное окружение Python ---
call venv\Scripts\activate.bat

REM --- Запускаем сам генератор ---
python generate.py

REM ==========================================================================
REM  СЮДА код доходит, когда generate.py завершился (нормально или с ошибкой).
REM  ВОЗВРАЩАЕМ нормальный сон (15 минут). Если хочешь другое число —
REM  поменяй 15 на нужное количество минут в четырёх строках ниже.
REM ==========================================================================
echo.
echo ==========================================================
echo  РАБОТА ЗАВЕРШЕНА. Возвращаю обычный режим сна (15 минут).
echo ==========================================================
powercfg /change standby-timeout-ac 15
powercfg /change standby-timeout-dc 15
powercfg /change hibernate-timeout-ac 15
powercfg /change hibernate-timeout-dc 15

echo.
echo Готово. Можешь закрыть это окно.
pause
