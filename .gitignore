# --- Виртуальное окружение Python (у каждого своё, в репозиторий не нужно) ---
venv/

# --- ГЛАВНОЕ: файл сессии входа = ключ от аккаунта. НИКОГДА не коммитим! ---
storage_state.json
auth.json

# --- Личные настройки и секреты ---
.env

# --- Рабочие папки с картинками/видео (содержимое не храним в репозитории) ---
INPUT/*
OUTPUT/*
DONE/*
logs/*

# --- Но сами пустые папки сохраняем, чтобы структура была видна (см. ниже) ---
!INPUT/.gitkeep
!OUTPUT/.gitkeep
!DONE/.gitkeep
!logs/.gitkeep

# --- Служебные файлы Python ---
__pycache__/
*.pyc

# --- Служебные файлы редакторов и ОС ---
.vscode/
Thumbs.db
desktop.ini

# Рабочие лог-файлы (могут содержать имена картинок и детали запусков) —
# в публичный репозиторий их не пускаем. Саму папку logs/ оставляем
# (она держится через logs/.gitkeep), а вот её содержимое — игнорируем.
logs/*.txt
